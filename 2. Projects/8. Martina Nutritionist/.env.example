# Telegram Bot Token — get this from BotFather on Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Martina's Telegram user ID — find it by messaging @userinfobot on Telegram
ALLOWED_USER_ID=123456789

# Gemini API Key — get this from https://aistudio.google.com/apikey (free)
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Service Account — paste the entire JSON as one line (or use a file path)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
